{
  "name": "manya-intelligence-os",
  "version": "1.0.0",
  "private": true,
  "description": "MANYA Intelligence OS — a sovereign, modular, local-first intelligence operating system. Conceived, directed, and owned by Uviwe Menyiwe (Azura Daemon), founder of the Manya Hael Foundation.",
  "author": "Uviwe Menyiwe (Azura Daemon) <foundation@manyahael.org>",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/build-package.js --all && node scripts/build-types.js --all",
    "build:fast": "node scripts/build-package.js --all --no-types",
    "build:types": "node scripts/build-types.js --all",
    "build:bundle": "node scripts/build-super-bundle.js",
    "build:prod": "node scripts/build-package.js --all && node scripts/build-types.js --all && node scripts/build-super-bundle.js",
    "build:analyze": "node scripts/build-super-bundle.js && node scripts/analyze-bundle.js",
    "clean": "rm -rf packages/*/dist packages/*/node_modules dist build",
    "test": "jest --config jest.config.js",
    "test:fast": "NODE_OPTIONS='--max-old-space-size=4096' jest --config jest.config.js --maxWorkers=75%",
    "test:coverage": "jest --coverage --config jest.config.js",
    "lint": "echo 'anya] lint placeholder — wire eslint in production'",
    "typecheck": "tsc -b --noEmit",
    "typecheck:parallel": "node scripts/typecheck-all.js",
    "bench": "node scripts/run-benchmarks.js"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^15.2.0",
    "@rollup/plugin-typescript": "^11.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "rollup": "^4.62.0",
    "rollup-plugin-dts": "^6.1.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "manya",
    "intelligence-os",
    "sovereign",
    "local-first",
    "ai",
    "agents",
    "identity",
    "governance",
    "memory"
  ],
  "homepage": "https://github.com/manya-hael/intelligence-os",
  "repository": {
    "type": "git",
    "url": "https://github.com/manya-hael/intelligence-os.git"
  }
}
