# Dependencies
node_modules/
**/node_modules/

# Build artifacts
*.tsbuildinfo
.tsbuildinfo
# dist/ and packages/*/dist/ are intentionally NOT ignored: this repo has
# no plain-JS fallback, so the compiled output must ship for the packages
# to be usable without a local build (which needs typescript/rollup/esbuild).

# Bundle metafile
dist/metafile.json

# Test cache
.jest-cache/

