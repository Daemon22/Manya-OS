{
  "name": "@manya/ledger",
  "version": "1.0.0",
  "description": "Immutable audit ledger with cryptographic chaining, Merkle proofs, and distributed sync for the MANYA Intelligence OS.",
  "main": "dist/cjs/index.js",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-package.js ledger",
    "test": "jest",
    "clean": "rm -rf dist build node_modules",
    "build:types": "node ../../scripts/build-types.js ledger",
    "build:bundle": "node ../../scripts/build-package.js ledger --no-types && node ../../scripts/build-types.js ledger"
  },
  "keywords": [
    "manya",
    "ledger",
    "audit",
    "merkle",
    "tamper-evident",
    "blockchain"
  ],
  "author": "Uviwe Menyiwe (Azura Daemon) <foundation@manyahael.org>",
  "license": "Apache-2.0",
  "dependencies": {},
  "devDependencies": {},
  "module": "dist/esm/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.mjs",
      "default": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
