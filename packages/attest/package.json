{
  "name": "@manya/attest",
  "version": "1.0.0",
  "description": "Device and session attestation for the MANYA Intelligence OS.",
  "main": "dist/cjs/index.js",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/build-package.js attest",
    "test": "jest",
    "clean": "rm -rf dist build node_modules",
    "build:types": "node ../../scripts/build-types.js attest",
    "build:bundle": "node ../../scripts/build-package.js attest --no-types && node ../../scripts/build-types.js attest"
  },
  "keywords": [
    "manya",
    "attestation",
    "device",
    "session",
    "trust",
    "security"
  ],
  "author": "Uviwe Menyiwe (Azura Daemon) <foundation@manyahael.org>",
  "license": "Apache-2.0",
  "dependencies": {},
  "devDependencies": {},
  "module": "dist/esm/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.mjs",
      "default": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
