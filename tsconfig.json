{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "composite": true,
    "incremental": true,
    "resolveJsonModule": true,
    "tsBuildInfoFile": "./.tsbuildinfo",
    "baseUrl": "./",
    "paths": {
      "@manya/keyring": ["packages/keyring/src"],
      "@manya/attest": ["packages/attest/src"],
      "@manya/ledger": ["packages/ledger/src"],
      "@manya/anonymize": ["packages/anonymize/src"],
      "@manya/customs-shield": ["packages/customs-shield/src"],
      "@manya/weave": ["packages/weave/src"],
      "@manya/contracts": ["packages/contracts/src"],
      "@manya/cortex": ["packages/cortex/src"],
      "@manya/memory": ["packages/memory/src"],
      "@manya/constitution": ["packages/constitution/src"],
      "@manya/council": ["packages/council/src"],
      "@manya/nervous-system": ["packages/nervous-system/src"]
    }
  },
  "files": [],
  "references": [
    { "path": "packages/keyring" },
    { "path": "packages/attest" },
    { "path": "packages/ledger" },
    { "path": "packages/anonymize" },
    { "path": "packages/customs-shield" },
    { "path": "packages/weave" },
    { "path": "packages/contracts" },
    { "path": "packages/cortex" },
    { "path": "packages/memory" },
    { "path": "packages/constitution" },
    { "path": "packages/council" },
    { "path": "packages/nervous-system" }
  ]
}
